<!--
  Stepora Mobile — Android Manifest
  Includes: permissions, deep linking, FCM, Stripe redirect handling.

  SECURITY TODO [V-243]: Tapjacking / Overlay Attack Protection.
  Add android:filterTouchesWhenObscured="true" to sensitive views
  (payment screens, login, biometric prompts) in their XML layouts
  or set it programmatically. React Native views should be wrapped
  with filterTouchesWhenObscured in the native MainActivity.
  See: https://developer.android.com/reference/android/view/View#security

  SECURITY TODO [V-239/V-261]: Add FLAG_SECURE to sensitive screens to
  prevent screenshots, screen recording, and task switcher thumbnails.
  In MainActivity.onCreate(): getWindow().setFlags(FLAG_SECURE, FLAG_SECURE);
  Or selectively per-screen via a React Native bridge module.

  SECURITY TODO [V-232]: Add root/jailbreak detection using SafetyNet
  (Play Integrity API) or a library like rootbeer. Warn users on
  rooted devices that token security is reduced.

  SECURITY TODO [V-256]: Add Play Integrity (Android) / App Attest (iOS)
  to verify that API requests come from genuine app instances.
  Backend should validate attestation tokens on sensitive endpoints.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.stepora.app">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <!-- Android 13+ notification permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Camera for avatar uploads and video calls -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Microphone for voice/video calls (Agora) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- Bluetooth for audio routing during calls -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:name=".MainApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:theme="@style/AppTheme"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false">

        <!-- Main Activity (V-243: filterTouchesWhenObscured for tapjacking protection) -->
        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:filterTouchesWhenObscured="true"
            android:exported="true">

            <!-- Standard launcher intent -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link: custom URL scheme -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.stepora.app" />
            </intent-filter>

            <!-- Universal links: stepora.app -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                    android:host="stepora.app" />
            </intent-filter>

            <!-- Stripe redirect handling -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.stepora.app"
                    android:host="subscription"
                    android:pathPrefix="/success" />
            </intent-filter>
        </activity>

        <!-- Firebase Cloud Messaging Service -->
        <service
            android:name="io.invertase.firebase.messaging.RNFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- FCM default notification channel -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="stepora-default" />

        <!-- FCM default notification icon -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_notification" />

        <!-- FCM default notification color (Stepora purple) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />

        <!-- Stripe publishable key (set via BuildConfig or runtime) -->
        <meta-data
            android:name="com.stripe.android.publishable_key"
            android:value="" />

        <!-- React Native Splash Screen -->
        <meta-data
            android:name="com.stepora.splash_screen"
            android:value="true" />

    </application>
</manifest>
