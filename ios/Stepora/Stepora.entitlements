<!--
  Stepora Mobile — iOS Entitlements
  Universal links (Associated Domains) and push notification capability.

  TODO: In Xcode, set the Development Team (DEVELOPMENT_TEAM) in the
  "Signing & Capabilities" tab for both Debug and Release configurations.
  Your Apple Developer Team ID is a 10-character alphanumeric string found at:
  https://developer.apple.com/account — Membership section.
  Also update the apple-app-site-association file in assets/universal-links/
  replacing TEAM_ID_HERE with the same Team ID.
-->
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Associated Domains for Universal Links -->
    <key>com.apple.developer.associated-domains</key>
    <array>
        <string>applinks:stepora.app</string>
        <string>applinks:api.stepora.app</string>
    </array>

    <!-- Push Notifications -->
    <key>aps-environment</key>
    <string>production</string>

    <!-- Keychain Sharing (for biometric key storage) -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.stepora.app</string>
    </array>
</dict>
</plist>
